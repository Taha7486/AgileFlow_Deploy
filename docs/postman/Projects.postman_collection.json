{
  "info": {
    "name": "AgileFlow Projects",
    "_postman_id": "d09e9cbc-85f2-4a73-b01f-ff197ed8473f",
    "description": "Collection Postman pour tester le CRUD projets et le dashboard.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Projects",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/projects"
      }
    },
    {
      "name": "Create Project",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Portail Web\",\n  \"description\": \"Projet client prioritaire\",\n  \"startDate\": \"2026-04-22\",\n  \"endDate\": \"2026-06-15\",\n  \"status\": \"ACTIF\",\n  \"managerId\": 2\n}"
        },
        "url": "{{baseUrl}}/projects"
      }
    },
    {
      "name": "Update Project",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Portail Web v2\",\n  \"description\": \"Perimetre etendu\",\n  \"startDate\": \"2026-04-22\",\n  \"endDate\": \"2026-06-30\",\n  \"status\": \"ACTIF\",\n  \"managerId\": 2\n}"
        },
        "url": "{{baseUrl}}/projects/{{projectId}}"
      }
    },
    {
      "name": "Delete Project",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/projects/{{projectId}}"
      }
    },
    {
      "name": "Dashboard Stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/dashboard/stats"
      }
    },
    {
      "name": "Get Project Backlog",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/backlogs/project/{{projectId}}?priority=HIGH"
      }
    },
    {
      "name": "Create User Story",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"En tant que PO je peux prioriser le backlog\",\n  \"description\": \"Ajout d'une user story avec priorite\",\n  \"priority\": \"HIGH\",\n  \"storyPoints\": 5,\n  \"acceptanceCriteria\": \"La story apparait dans la liste du backlog\"\n}"
        },
        "url": "{{baseUrl}}/backlogs/project/{{projectId}}/stories"
      }
    },
    {
      "name": "Update User Story",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"En tant que PO je peux filtrer le backlog\",\n  \"description\": \"Mise a jour de la priorite\",\n  \"priority\": \"CRITICAL\",\n  \"storyPoints\": 8,\n  \"acceptanceCriteria\": \"Le filtre par priorite fonctionne\"\n}"
        },
        "url": "{{baseUrl}}/user-stories/{{storyId}}"
      }
    },
    {
      "name": "Assign Story To Sprint",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/user-stories/{{storyId}}/assign-sprint/{{sprintId}}"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "projectId",
      "value": "1"
    },
    {
      "key": "storyId",
      "value": "1"
    },
    {
      "key": "sprintId",
      "value": "1"
    }
  ]
}
